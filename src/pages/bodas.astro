---
// Gerado a partir de: bodas.html
import { Fragment } from 'astro/jsx-runtime';
import Base from '../layouts/Base.astro';
import config from '../../config.json';
import Img from '../components/ui/Img.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import '../styles/bodas.css';
---

<Base
  title="Bodas — Villa Cidade Jardim"
  description="Celebre sua história de amor no Villa Cidade Jardim. Cenários personalizados, infraestrutura completa e gastronomia autoral para suas bodas."
  ogImage="/images/og-default.jpg"
  canonical="https://villacidadejd.com.br/bodas/"
  whatsappEventTypes={[
    { value: 'Bodas',                    label: 'Bodas'                    },
    { value: 'Casamento',                label: 'Casamento'                },
    { value: 'Confraternização social',  label: 'Confraternização social'  },
    { value: 'Outros',                   label: 'Outros'                   },
  ]}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://npmcdn.com/flatpickr/dist/flatpickr.min.css" media="print" onload="this.media='all'" />
  </Fragment>

  <!-- Cabeçalho com Logotipo -->
  <header class="bodas-header" id="meu-header-fixo">
    <div class="logo-container">
      <Img src="logo_villa_cidade_jardim-semfundo.png" alt="Villa Cidade Jardim" class="header-logo" priority />
    </div>
  </header>

  <main>
    <!-- Seção Hero -->
    <section class="bodas-hero">
      <div class="bodas-hero-bg-wrapper">
        <Img src="MG_9250-1-scaled.avif" alt="" priority class="bodas-hero-bg" />
      </div>
      <div class="bodas-hero-content">
        <h1 class="bodas-hero-title">Celebre sua história de amor com a emoção que ela merece.</h1>
        <p class="bodas-hero-subtitle">No Villa Cidade Jardim, cada renovação de votos com cenários personalizados e gastronomia autoral.</p>
        <a href="#contato" class="bodas-hero-cta">Solicite uma proposta</a>
      </div>
    </section>

    <!-- Seção 2: Um espaço que se adapta... -->
    <section class="bodas-split-section">
      <div class="bodas-split-image"></div>
      <div class="bodas-split-text-container">
        <div class="bodas-split-text-content">
          <h2 class="bodas-section-title">Um espaço que se adapta à sua celebração!</h2>
          <p class="bodas-section-text">
            Há mais de uma década, o Villa Cidade Jardim transforma encontros em celebrações carregadas de significados. Integrado ao Shopping Cidade Jardim, nosso espaço oferece liberdade criativa, atenção absoluta aos detalhes e um time dedicado a desenhar cada boda de forma única.
          </p>
        </div>
      </div>
    </section>

    <!-- Seção 3: Ambientes que se moldam... -->
    <section class="bodas-gallery-section">
      <div class="bodas-gallery-header">
        <h2 class="bodas-section-title">Ambientes que se moldam à sua comemoração.</h2>
        <p class="bodas-gallery-subtitle">Oferecemos ambientes versáteis e composições personalizadas, criando cenários que refletem a essência do casal.</p>
      </div>

      <div class="bodas-gallery-grid">
        <div class="bodas-gallery-item">
          <Img src="WhatsApp-Image-2026-01-27-at-10.49.03.avif" alt="Espaço Villa Cidade Jardim - Boda 1" />
          <div class="bodas-gallery-overlay"></div>
        </div>
        <div class="bodas-gallery-item">
          <Img src="MG_9222-scaled.avif" alt="Espaço Villa Cidade Jardim - Boda 2" />
          <div class="bodas-gallery-overlay"></div>
        </div>
        <div class="bodas-gallery-item">
          <Img src="WhatsApp-Image-2026-01-27-at-10.49.03-1.avif" alt="Espaço Villa Cidade Jardim - Boda 3" />
          <div class="bodas-gallery-overlay"></div>
        </div>
        <div class="bodas-gallery-item">
          <Img src="MG_9220-1-scaled.avif" alt="Espaço Villa Cidade Jardim - Boda 4" />
          <div class="bodas-gallery-overlay"></div>
        </div>
      </div>
    </section>

    <!-- Seção 4: Infraestrutura pensada... -->
    <section class="bodas-features-section">
      <h2 class="bodas-features-title">Cuidamos de tudo para que seu evento seja perfeito.</h2>
      <p class="bodas-features-subtitle">Infraestrutura pensada para trazer conforto aos convidados.</p>
      
      <div class="bodas-features-grid">
        <!-- Feature 1: Equipe operacional -->
        <div class="bodas-feature-card">
          <div class="bodas-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <span class="bodas-feature-label">Equipe<br/>operacional</span>
        </div>

        <!-- Feature 2: Mobiliário Completo -->
        <div class="bodas-feature-card">
          <div class="bodas-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 9V6a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v3"></path>
              <path d="M3 16a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v5z"></path>
              <path d="M6 18v3"></path>
              <path d="M18 18v3"></path>
            </svg>
          </div>
          <span class="bodas-feature-label">Mobiliário<br/>Completo</span>
        </div>

        <!-- Feature 3: Bar de Drinks -->
        <div class="bodas-feature-card">
          <div class="bodas-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 22h8"></path>
              <path d="M12 11v11"></path>
              <path d="m19 3-7 8-7-8Z"></path>
            </svg>
          </div>
          <span class="bodas-feature-label">Bar de<br/>Drinks</span>
        </div>

        <!-- Feature 4: Decoração -->
        <div class="bodas-feature-card">
          <div class="bodas-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M12 2a4 4 0 0 0-4 4 4 4 0 0 0 4 4 4 4 0 0 0 4-4 4 4 0 0 0-4-4z"></path>
              <path d="M12 14a4 4 0 0 0-4 4 4 4 0 0 0 4 4 4 4 0 0 0 4-4 4 4 0 0 0-4-4z"></path>
              <path d="M2 12a4 4 0 0 0 4 4 4 4 0 0 0 4-4 4 4 0 0 0-4-4 4 4 0 0 0-4 4z"></path>
              <path d="M14 12a4 4 0 0 0 4 4 4 4 0 0 0 4-4 4 4 0 0 0-4-4 4 4 0 0 0-4 4z"></path>
            </svg>
          </div>
          <span class="bodas-feature-label">Decoração</span>
        </div>

        <!-- Feature 5: Som e luz -->
        <div class="bodas-feature-card">
          <div class="bodas-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect>
              <circle cx="12" cy="14" r="4"></circle>
              <line x1="12" y1="6" x2="12.01" y2="6"></line>
            </svg>
          </div>
          <span class="bodas-feature-label">Som e luz</span>
        </div>

        <!-- Feature 6: Estacionamento -->
        <div class="bodas-feature-card">
          <div class="bodas-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="22" height="13" rx="2" ry="2"></rect>
              <path d="M7 16H3v2a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-2z"></path>
              <path d="M21 16h-4v2a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-2z"></path>
              <path d="M14 8H10V6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2z"></path>
              <circle cx="6" cy="12" r="1.5"></circle>
              <circle cx="18" cy="12" r="1.5"></circle>
            </svg>
          </div>
          <span class="bodas-feature-label">Estacionamento</span>
        </div>

        <!-- Feature 7: Gerador -->
        <div class="bodas-feature-card">
          <div class="bodas-feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
            </svg>
          </div>
          <span class="bodas-feature-label">Gerador</span>
        </div>
      </div>
    </section>

    <!-- Seção 5: Alta Gastronomia -->
    <section class="bodas-gastronomy-section">
      <div class="bodas-gastronomy-text-container">
        <div class="bodas-gastronomy-text-content">
          <h2 class="bodas-gastronomy-title">Alta Gastronomia</h2>
          <p class="bodas-gastronomy-text">
            Cada menu é personalizado, combinando seus sabores preferidos. São pratos que contam histórias e fazem do jantar um momento especial da festa.
          </p>
        </div>
      </div>
      <div class="bodas-gastronomy-carousel">
        <div class="bodas-carousel-slide active">
          <Img src="WhatsApp-Image-2026-01-27-at-10.49.04-1.avif" alt="Alta Gastronomia - Villa Cidade Jardim 1" />
        </div>
        <div class="bodas-carousel-slide">
          <Img src="WhatsApp-Image-2026-01-27-at-10.49.04.avif" alt="Alta Gastronomia - Villa Cidade Jardim 2" />
        </div>
      </div>
    </section>

    <!-- Seção 6: Contato -->
    <section class="bodas-contact-section" id="contato">
      <div class="bodas-contact-container">
        <div class="bodas-contact-info">
          <h2 class="bodas-contact-title">Vamos celebrar juntos as suas bodas?</h2>
          <p class="bodas-contact-subtitle">Preencha o formulário para receber nosso contato.</p>
        </div>

        <div class="bodas-form-card">
          <LeadForm
            formId="form_bodas"
            project={config.project_slug}
            submitUrl={config.forms['lead-form'].webhooks[0]}
            redirectUrl={config.forms['lead-form'].redirect_on_success}
            submitText="ENVIAR SOLICITAÇÃO"
            honeypot
            prefix="bodas"
            fields={[
              { name: 'nome', type: 'text', placeholder: 'Nome', required: true },
              {
                type: 'row',
                fields: [
                  { name: 'telefone', type: 'tel', placeholder: 'WhatsApp', required: true },
                  { name: 'email', type: 'email', placeholder: 'E-mail', required: true }
                ]
              },
              {
                name: 'tipo',
                type: 'select',
                required: true,
                options: [
                  { value: '', label: 'Tipo de evento:', disabled: true },
                  { value: 'Bodas', label: 'Bodas', selected: true },
                  { value: 'Casamento', label: 'Casamento' },
                  { value: 'Confraternização social', label: 'Confraternização social' },
                  { value: 'Outros', label: 'Outros' }
                ]
              },
              { name: 'data', type: 'text', placeholder: 'Data do Evento', required: true, id: 'bodas-data-evento', readonly: true },
              { name: 'convidados', type: 'number', placeholder: 'N° de Pessoas', required: true },
              { name: 'mensagem', type: 'textarea', placeholder: 'Detalhes adicionais: (Não obrigatório)', required: false, rows: 4 }
            ]}
          />
        </div>
      </div>
    </section>
  </main>

  <!-- Rodapé -->
  <footer class="bodas-footer">
    <div class="footer-container">
      <div class="footer-copyright">
        <p>© 2026 Villa Cidade Jardim - Todos os direitos reservados</p>
      </div>
      
      <div class="footer-brand">
        <Img src="logo_villa_cidade_jardim-semfundo.png" alt="Villa Cidade Jardim" class="footer-logo" />
      </div>
      
      <div class="footer-developer">
        <span>Desenvolvido por:</span>
        <a href="http://dmove.com.br" target="_blank" rel="noopener noreferrer">
          <Img src="Versao-Principal-Negativo-scaled-e1750426923582.avif" alt="Dmove" class="developer-logo" />
        </a>
      </div>
    </div>
  </footer>

  <!-- Flatpickr & Carousel Scripts -->
  <script is:inline>
    // 1. Calendário Flatpickr
    document.addEventListener('DOMContentLoaded', () => {
      const dateInput = document.getElementById('bodas-data-evento');
      if (dateInput && window.flatpickr) {
        window.flatpickr(dateInput, {
          disableMobile: true,
          dateFormat: 'd/m/Y',
          locale: {
            weekdays: {
              shorthand: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'],
              longhand: ['Domingo', 'Segunda-feira', 'Terça-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'Sábado'],
            },
            months: {
              shorthand: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'],
              longhand: ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'],
            },
            firstDayOfWeek: 1,
            ordinal: () => 'º',
          },
        });
      }
    });

    // 2. Carrossel de Gastronomia (Alternância suave de slides)
    document.addEventListener('DOMContentLoaded', () => {
      const slides = document.querySelectorAll('.bodas-carousel-slide');
      if (slides.length > 1) {
        let currentIndex = 0;
        setInterval(() => {
          slides[currentIndex].classList.remove('active');
          currentIndex = (currentIndex + 1) % slides.length;
          slides[currentIndex].classList.add('active');
        }, 4000);
      }
    });

    // 3. Header Transparente com Efeito de Scroll
    document.addEventListener('DOMContentLoaded', () => {
      const header = document.getElementById('meu-header-fixo');
      const secoes = Array.from(document.querySelectorAll('main > section'));

      if (!header || secoes.length < 2) {
        return;
      }

      const indiceInicio = 1;
      const indiceFim = secoes.length - 1;

      const segundaSecao = secoes[indiceInicio];
      const secaoFinal = secoes[indiceFim];

      function verificarScroll() {
        if (!segundaSecao || !secaoFinal) return;

        const posicaoScroll = window.scrollY;
        const pontoInicio = segundaSecao.offsetTop - 100;
        const pontoFim = secaoFinal.offsetTop;

        if (posicaoScroll >= pontoInicio && posicaoScroll < pontoFim) {
          header.classList.add('cor-ativa');
        } else {
          header.classList.remove('cor-ativa');
        }
      }

      window.addEventListener('scroll', verificarScroll);
      verificarScroll();
    });
  </script>

  <Fragment slot="scripts">
    <script is:inline src="https://npmcdn.com/flatpickr/dist/flatpickr.min.js" defer></script>
  </Fragment>
</Base>
